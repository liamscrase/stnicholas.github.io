---
import Layout from "../../../layouts/Layout.astro";
import PageH1 from "../../../components/PageH1.astro";
import type { GetStaticPaths, Page } from "astro";
import "../../../styles/learning.scss";

export const getStaticPaths = (async ({ paginate }) => {
  const resources = [
    {
      name: "The Orthodox Study Bible",
      description: "The first Orthodox study Bible in English, with commentary drawn from the Church Fathers and the Septuagint Old Testament.",
      link: "https://www.amazon.com/Orthodox-Study-Bible-Hardcover-Christianity/dp/0718003594",
      type: "Book",
      image: "/images/learning/orthodox-study-bible.jpg"
    },
    {
      name: "The Law of God",
      description: "The standard Russian Orthodox catechism by Fr. Seraphim Slobodskoy — covering the faith, sacraments, and liturgical life from the ground up.",
      link: "https://www.amazon.com/dp/0884650111",
      type: "Book",
      image: "/images/line-art/book-chalice.svg"
    },
    {
      name: "The Way of a Pilgrim",
      description: "A beloved anonymous Russian classic following a pilgrim who learns to pray the Jesus Prayer without ceasing.",
      link: "https://www.amazon.com/dp/0385468725",
      type: "Book",
      image: "/images/line-art/priest.svg"
    },
    {
      name: "For the Life of the World",
      description: "Fr. Alexander Schmemann's foundational introduction to Orthodox theology and the meaning of the Divine Liturgy.",
      link: "https://www.amazon.com/dp/0913836087",
      type: "Book",
      image: "/images/learning/for-the-life-of-the-world.jpg"
    },
    {
      name: "Ancient Faith Radio",
      description: "Podcasts, music, and teachings covering the breadth of Orthodox Christian life and tradition.",
      link: "https://www.ancientfaith.com/",
      type: "Website",
      image: "/images/line-art/vespers.svg"
    },
    {
      name: "Orthodox Wiki",
      description: "A comprehensive online encyclopedia of Orthodox Christianity, saints, theology, and history.",
      link: "https://orthodoxwiki.org/",
      type: "Website",
      image: "/images/line-art/christ.svg"
    },
  ];

  return paginate(resources, { pageSize: 9 });
}) satisfies GetStaticPaths;

type Resource = { name: string; description: string; link: string; type: string; image: string };
type Props = {
  page: Page<Resource>;
};

const { page } = Astro.props;
---

<Layout
  title="Learning - St. Nicholas Orthodox Church"
  description="Discover Orthodox Christian learning resources, recommended channels, websites, and study materials."
>
  <div class="content">
    <PageH1
      title="Learning"
      subheader="Explore resources to deepen your understanding of Orthodox Christianity."
    />
    <div class="grid-3-col">
      {page.data.map((resource) => (
        <div class="grid-card">
          <img src={resource.image} alt={resource.name} class="line-art" />
          <h3>{resource.name}</h3>
          <p class="resource-type">{resource.type}</p>
          <p>{resource.description}</p>
          <a href={resource.link} target="_blank" rel="noopener noreferrer" class="button primary small">Visit</a>
        </div>
      ))}
    </div>

    {page.lastPage > 1 && (
      <nav class="pagination" aria-label="Pagination">
        {page.url.prev && (
          <a href={page.url.prev} class="button tertiary small pagination-link">← Previous</a>
        )}
        <span class="pagination-info">Page {page.currentPage} of {page.lastPage}</span>
        {page.url.next && (
          <a href={page.url.next} class="button tertiary small pagination-link">Next →</a>
        )}
      </nav>
    )}
  </div>
</Layout>
