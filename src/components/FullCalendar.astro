---
// Fetched at BUILD TIME — API key never reaches the browser.
// Rename your .env.local vars:
//   PUBLIC_GOOGLE_CALENDAR_ID        → GOOGLE_CALENDAR_ID
//   PUBLIC_GOOGLE_CALENDAR_API_KEY   → GOOGLE_CALENDAR_API_KEY
const calendarId = import.meta.env.GOOGLE_CALENDAR_ID ?? "";
const apiKey = import.meta.env.GOOGLE_CALENDAR_API_KEY ?? "";

let events: Array<{
  id: string;
  title: string;
  start: string | undefined;
  end: string | undefined;
  extendedProps: { description: string; location: string };
}> = [];

if (calendarId && apiKey) {
  try {
    const url = new URL(
      `https://www.googleapis.com/calendar/v3/calendars/${encodeURIComponent(calendarId)}/events`
    );
    url.searchParams.set("key", apiKey);
    url.searchParams.set("orderBy", "startTime");
    url.searchParams.set("singleEvents", "true");
    url.searchParams.set("timeMin", new Date().toISOString());

    const res = await fetch(url.toString());
    if (!res.ok) {
      const errData = await res.json();
      throw new Error(errData?.error?.message ?? `HTTP ${res.status}`);
    }
    const data = await res.json();
    events = (data.items ?? []).map((ev: any) => ({
      id: ev.id,
      title: ev.summary || "(No title)",
      start: ev.start?.dateTime ?? ev.start?.date,
      end: ev.end?.dateTime ?? ev.end?.date,
      extendedProps: {
        description: ev.description ?? "",
        location: ev.location ?? "",
      },
    }));
  } catch (e: any) {
    console.error("[FullCalendar] Build-time fetch failed:", e.message);
  }
}
---

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.20/index.global.min.css" />
<script is:inline src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.20/index.global.min.js" id="fullcalendar-cdn"></script>

<div class="calendar-wrapper" role="region" aria-label="Event Calendar">
  <div id="calendar-loading" aria-live="polite" class="calendar-loading">
    <div class="spinner" aria-hidden="true"></div>
    <span>Loading calendar…</span>
  </div>
  <div id="fullcalendar" style="visibility:hidden;" data-events={JSON.stringify(events)}></div>

  <dialog id="event-dialog" class="event-dialog">
    <button class="dialog-close" aria-label="Close" id="dialog-close">✕</button>
    <h2 class="dialog-title" id="dialog-title"></h2>
    <p id="dialog-time" class="dialog-time"></p>
    <p id="dialog-location" class="dialog-location"></p>
    <p id="dialog-description" class="dialog-description"></p>
  </dialog>
</div>

<script is:inline>
  function initCalendar(events) {
    const el = document.getElementById("fullcalendar");
    const loadingEl = document.getElementById("calendar-loading");
    const dialog = document.getElementById("event-dialog");
    const dialogClose = document.getElementById("dialog-close");

    if (!el) return;

    const isMobile = () => window.innerWidth < 640;

    const calendar = new FullCalendar.Calendar(el, {
      contentHeight: "auto",
      initialView: isMobile() ? "listMonth" : "dayGridMonth",
      headerToolbar: {
        left: "prev,next today",
        center: "title",
        right: "dayGridMonth,listMonth",
      },
      buttonText: {
        today: "Today",
        month: "Month",
        list: "List",
      },
      events,
      eventTimeFormat: {
        hour: "numeric",
        minute: "2-digit",
        omitZeroMinute: true,
        meridiem: "short",
      },
      eventClick({ event }) {
        if (!dialog) return;

        const fmt = (dt) =>
          dt
            ? new Date(dt).toLocaleString(undefined, {
                weekday: "short",
                month: "short",
                day: "numeric",
                year: "numeric",
                hour: "2-digit",
                minute: "2-digit",
              })
            : "";

        document.getElementById("dialog-title").textContent = event.title;
        document.getElementById("dialog-time").textContent = event.start
          ? `${fmt(event.startStr)}${event.end ? " → " + fmt(event.endStr) : ""}`
          : "";

        const loc = event.extendedProps?.location;
        const locEl = document.getElementById("dialog-location");
        locEl.textContent = loc ? `📍 ${loc}` : "";
        locEl.style.display = loc ? "" : "none";

        const desc = event.extendedProps?.description;
        const descEl = document.getElementById("dialog-description");
        descEl.textContent = desc ?? "";
        descEl.style.display = desc ? "" : "none";

        dialog.showModal();
      },
      windowResize() {
        calendar.changeView(isMobile() ? "listMonth" : "dayGridMonth");
      },
    });

    calendar.render();
    el.style.visibility = "visible";
    loadingEl?.remove();

    dialogClose?.addEventListener("click", () => dialog?.close());
    dialog?.addEventListener("click", (e) => {
      if (e.target === dialog) dialog.close();
    });
  }

  function start() {
    if (typeof FullCalendar === "undefined") {
      document.getElementById("fullcalendar-cdn")?.addEventListener("load", start);
      return;
    }
    const el = document.getElementById("fullcalendar");
    const events = JSON.parse(el?.dataset.events ?? "[]");
    initCalendar(events);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", start);
  } else {
    start();
  }
</script>
