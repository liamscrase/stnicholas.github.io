        <li class="dropdown">

        <a href="#" class="dropdown-toggle">Our Parish</a>

        <ul class="dropdown-menu">
          <li><a href="/parish-news/">Parish News</a></li>
          <li><a href="/icon-gallery/">Icon Gallery</a></li>
          <li><a href="/historical-gallery/">Historical Gallery</a></li>
        </ul>
        </li>
      </ul>
    </div>
    <a href="/"><img class="logo" src="/images/logo-main.svg" alt="St. Nicholas Logo" /></a>
    <div class="nav-links">
      <ul>
        <li class="dropdown">
          <a href="#" class="dropdown-toggle">Library</a>
