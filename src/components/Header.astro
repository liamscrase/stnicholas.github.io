<nav class="mobile-navbar">
  <input type="checkbox" id="menu-toggle" class="menu-toggle" />
  <div class="mobile-navbar-container">
    <a href="/"><img class="logo" src="/images/logo-main.svg" alt="St. Nicholas Logo" width="218" height="218" /></a>
    <label for="menu-toggle" class="hamburger">
      <span></span>
      <span></span>
      <span></span>
    </label>
  </div>
  <div class="offcanvas-menu">
    <div class="menu-items">
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/schedule/">Schedule</a></li>
        <li class="offcanvas-dropdown">
          <button type="button" class="offcanvas-dropdown-toggle" aria-expanded="false" aria-controls="offcanvas-parish" id="offcanvas-parish-btn">Our Parish</button>
          <ul class="offcanvas-dropdown-menu" id="offcanvas-parish" role="region" aria-labelledby="offcanvas-parish-btn">
            <li><a href="/parish-news/">Parish News</a></li>
            <li><a href="/icon-gallery/">Icon Gallery</a></li>
            <li><a href="/historical-gallery/">Historical Gallery</a></li>
          </ul>
        </li>
        <li class="offcanvas-dropdown"> 
          <button type="button" class="offcanvas-dropdown-toggle" aria-expanded="false" aria-controls="offcanvas-library" id="offcanvas-library-btn">Library</button>
          <ul class="offcanvas-dropdown-menu" id="offcanvas-library" role="region" aria-labelledby="offcanvas-library-btn">
            <li><a href="/library/music/">Music</a></li>
            <li><a href="/library/service-texts/">Service Texts</a></li>
            <li><a href="/library/learning/">Learning</a></li>
          </ul>
        </li>
        <li><a href="/giving/">Giving</a></li>
        <li><a href="/contact/">Contact</a></li>
      </ul>
    </div>
  </div>
  <label for="menu-toggle" class="offcanvas-backdrop"></label>
</nav>

<script>
  document.querySelectorAll('.offcanvas-dropdown-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', (!expanded).toString());
      btn.parentElement?.classList.toggle('is-open', !expanded);
    });
  });
</script>